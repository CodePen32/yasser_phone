# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files — NEVER commit these
# NOTE: .env is needed by Prisma CLI (migrate/seed/studio)
# .env.local is read by Next.js at runtime
# Both must have the same DATABASE_URL
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/prisma/migrations/.gitkeep

# uploads
/public/uploads/*
!/public/uploads/.gitkeep
