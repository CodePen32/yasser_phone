// Prisma schema for Yasser Phone — MySQL
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Store Settings ──────────────────────────────────────────────────────────
model StoreSettings {
  id               Int      @id @default(autoincrement())
  store_name       String   @default("Yasser Phone")
  slogan           String?
  logo_url         String?
  favicon_url      String?
  whatsapp_number  String   @default("22232816779")
  phone            String?
  email            String?
  address          String?
  city             String   @default("نواكشوط")
  currency         String   @default("MRU")
  facebook_url     String?
  instagram_url    String?
  tiktok_url       String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("store_settings")
}

// ─── Categories ──────────────────────────────────────────────────────────────
model Category {
  id         Int       @id @default(autoincrement())
  name_ar    String
  slug       String    @unique
  image_url  String?
  sort_order Int       @default(0)
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  products   Product[]

  @@map("categories")
}

// ─── Brands ──────────────────────────────────────────────────────────────────
model Brand {
  id         Int       @id @default(autoincrement())
  name       String
  slug       String    @unique
  logo_url   String?
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  products   Product[]

  @@map("brands")
}

// ─── Products ────────────────────────────────────────────────────────────────
model Product {
  id               Int      @id @default(autoincrement())
  name_ar          String
  slug             String   @unique
  description_ar   String?  @db.Text
  price            Decimal  @db.Decimal(10, 2)
  old_price        Decimal? @db.Decimal(10, 2)
  discount_percent Int?
  currency         String   @default("MRU")
  main_image_url   String?
  brand_id         Int?
  category_id      Int?
  condition        String   @default("new") // new | used | refurbished
  storage          String?
  ram              String?
  color            String?
  warranty         String?
  is_featured      Boolean  @default(false)
  is_offer         Boolean  @default(false)
  is_active        Boolean  @default(true)
  stock_status     String   @default("in_stock") // in_stock | out_of_stock
  rating           Decimal? @db.Decimal(3, 1)
  review_count     Int      @default(0)
  bought_recently  Int      @default(0)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  brand    Brand?    @relation(fields: [brand_id], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  images   ProductImage[]
  specs    ProductSpec[]
  orders   WhatsappOrder[]

  @@map("products")
}

// ─── Product Images ───────────────────────────────────────────────────────────
model ProductImage {
  id         Int     @id @default(autoincrement())
  product_id Int
  image_url  String
  sort_order Int     @default(0)

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ─── Product Specs ────────────────────────────────────────────────────────────
model ProductSpec {
  id         Int    @id @default(autoincrement())
  product_id Int
  spec_name  String
  spec_value String

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_specs")
}

// ─── Admins ───────────────────────────────────────────────────────────────────
model Admin {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String
  role          String   @default("admin") // admin | superadmin
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("admins")
}

// ─── WhatsApp Orders (optional) ───────────────────────────────────────────────
model WhatsappOrder {
  id             Int      @id @default(autoincrement())
  product_id     Int?
  customer_name  String?
  customer_phone String?
  message        String?  @db.Text
  status         String   @default("new") // new | contacted | done
  created_at     DateTime @default(now())

  product Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)

  @@map("whatsapp_orders")
}
