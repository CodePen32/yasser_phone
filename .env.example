# ─── Database (Railway MySQL) ─────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Get this from: Railway → your MySQL service → Connect tab
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET="change-this-to-a-long-random-secret"

# ─── App URL ──────────────────────────────────────────────────────────────────
# Development: http://localhost:3000
# Production:  your Render URL or custom domain (no trailing slash)
NEXT_PUBLIC_APP_URL="https://your-app.onrender.com"

# ─── Cloudflare R2 (production image storage) ─────────────────────────────────
# Required only in production (NODE_ENV=production)
# In development, images are saved locally to public/uploads/ — leave these empty

# Your Cloudflare Account ID (dashboard.cloudflare.com → right sidebar)
R2_ACCOUNT_ID=

# R2 API token credentials (R2 → Manage API tokens → Create token with Object Write)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# R2 bucket name (must already exist in your Cloudflare account)
R2_BUCKET_NAME=yasser-phone-uploads

# Public base URL for images (no trailing slash). Either:
#   R2 custom domain:  https://cdn.yourdomain.com
#   R2 public URL:     https://pub-XXXX.r2.dev
R2_PUBLIC_BASE_URL=https://pub-XXXX.r2.dev
